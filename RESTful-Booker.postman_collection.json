          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Save ID to variables\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set(\"bookingID\", jsonData.bookingid);",
                  "});",
                  "",
                  "pm.test(\"Check first name is correct\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var requestBody = JSON.parse(pm.request.body.raw);",
                  "    pm.expect(jsonData.booking.firstname).to.eql(requestBody.firstname)",
                  "})",
                  "",
                  "pm.expect(pm.response.responseTime).to.be.below(500);",
                  "",
                  "const schema = JSON.parse(pm.collectionVariables.get(\"booking_schema_POST\"))",
                  "",
                  "pm.test(\"JSON validation schema\", function () {",
                  "    pm.response.to.have.jsonSchema(schema);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const moment = require('moment')\r",
                  "\r",
                  "const daysUntilCheckin = Math.floor(Math.random()*10)+1;\r",
                  "const stayDuration = Math.floor(Math.random*14)+1;\r",
                  "\r",
                  "const checkinDate = moment().add(daysUntilCheckin, 'days').format(\"YYYY-MM-DD\");\r",
                  "const checkoutDate = moment(checkinDate).add(stayDuration, 'days').format(\"YYYY-MM-DD\");\r",
                  "\r",
                  "const price = Math.floor(Math.random() * 1400) + 100;\r",
                  "\r",
                  "pm.variables.set(\"dynamic_checkin\", checkinDate);\r",
                  "pm.variables.set(\"dynamic_checkout\", checkoutDate);\r",
                  "pm.variables.set(\"dynamic_price\", price);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "accept": true
            }
          },
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"firstname\" : \"{{$randomFirstName}}\",\r\n    \"lastname\" : \"{{$randomLastName}}\",\r\n    \"totalprice\" : {{dynamic_price}},\r\n    \"depositpaid\" : true,\r\n    \"bookingdates\" : {\r\n        \"checkin\" : \"{{dynamic_checkin}}\",\r\n        \"checkout\" : \"{{dynamic_checkout}}\"\r\n    },\r\n    \"additionalneeds\" : \"Breakfast\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "booking"
              ]
            }
          },
          "response": []
