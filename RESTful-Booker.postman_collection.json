    {
      "name": "Partial Update - Bad data",
      "item": [
        {
          "name": "Partial Update - NaN date Bug",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.expect(pm.response.code).to.eql(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Date has right format\", function() {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    var dateRegex = /^\\d{4}-\\d{2}-\\d{2}$/;\r",
                  "    pm.expect(jsonData.bookingdates.checkin).to.match(dateRegex);\r",
                  "    pm.expect(jsonData.bookingdates.checkout).to.match(dateRegex);\r",
                  "})"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "protocolProfileBehavior": {
            "disabledSystemHeaders": {
              "accept": true
            }
          },
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
